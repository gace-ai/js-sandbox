{
  "name": "polyfill",
  "version": "1.0.0",
  "description": "Guest-side proxy shim for sandbox — bundled as self-contained IIFE for QuickJS",
  "type": "module",
  "main": "./dist/make-proxy.global.js",
  "exports": {
    ".": {
      "import": "./dist/make-proxy.global.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "packageManager": "pnpm@10.24.0",
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "~5.9.3"
  },
  "dependencies": {
    "communication-protocol": "workspace:*"
  }
}
