{
  "name": "@gace/sandbox",
  "version": "0.0.1",
  "description": "General purpose sandbox, that let's you pass a reference from host",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "keywords": [
    "sandbox",
    "quickjs",
    "proxy",
    "security"
  ],
  "packageManager": "pnpm@10.24.0",
  "devDependencies": {
    "communication-protocol": "workspace:*",
    "polyfill": "workspace:*",
    "quickjs-emscripten": "^0.32.0",
    "esbuild-raw-plugin": "^0.3.1",
    "tsup": "^8.0.0",
    "typescript": "~5.9.3"
  },
  "dependencies": {
    "@msgpack/msgpack": "^3.1.3"
  },
  "peerDependencies": {
    "quickjs-emscripten": "^0.32.0"
  }
}
